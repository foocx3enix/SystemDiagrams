        <mxCell id="5VOFnX5OII6aDvyBcTs3-34" parent="5VOFnX5OII6aDvyBcTs3-1" style="rounded=1;whiteSpace=wrap;html=1;" value="Route to&amp;nbsp;&lt;span style=&quot;color: rgb(210, 168, 255); background-color: rgb(18, 19, 20); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space: pre;&quot;&gt;processPending()&lt;/span&gt;&lt;div&gt;due to&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); text-align: left;&quot;&gt;MMTransactionAPI&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); text-align: left;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;substatus is pending&lt;/span&gt;&lt;/div&gt;" vertex="1">
