        </mxCell>
        <mxCell id="5VOFnX5OII6aDvyBcTs3-28" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;fontSize=18;align=left;" value="When&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(78, 201, 176), rgb(6, 112, 90)); background-color: light-dark(rgb(18, 19, 20), rgb(220, 221, 222)); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: center; white-space: pre;&quot;&gt;GlobalTransferTaskExecutor &lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(210, 168, 255), rgb(103, 67, 142)); background-color: light-dark(rgb(18, 19, 20), rgb(220, 221, 222)); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: center; white-space: pre;&quot;&gt;CreateRequestUser()&lt;/span&gt;, it does：&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Create MMRequest (Status: new)&lt;/div&gt;&lt;div&gt;2. Create MMTransactionAPI (Status: initiating, substatus: pending, type:&amp;nbsp;mc_remittance_transfer)&lt;/div&gt;&lt;div&gt;3. Create MMTransaction&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;(Status: pending, substatus: pending, type: mc_remittance_transfer)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;4. Update&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;MMRequest&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;(Status: pending)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;5. Send&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;MMTransactionAPI&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;&amp;nbsp;into channel&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="194" width="893" x="1312" y="1291" as="geometry" />
        </mxCell>
        <mxCell id="5VOFnX5OII6aDvyBcTs3-44" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;fontSize=18;align=left;" value="When&amp;nbsp;&lt;span style=&quot;color: rgb(78, 201, 176); background-color: rgb(18, 19, 20); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space: pre;&quot;&gt;GlobalTransferService &lt;/span&gt;&lt;span style=&quot;color: rgb(210, 168, 255); background-color: rgb(18, 19, 20); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space: pre;&quot;&gt;executeTransaction&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(210, 168, 255), rgb(103, 67, 142)); background-color: light-dark(rgb(18, 19, 20), rgb(220, 221, 222)); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; text-align: center; white-space: pre;&quot;&gt;()&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;, it does：&lt;/span&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Send request to MM to initiate the remittance transaction&lt;/div&gt;&lt;div&gt;2. Create MMRemittance&lt;/div&gt;&lt;div&gt;3. Update the&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;MMTransactionAPI&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;&amp;nbsp;with the request and response, regardless of the request success or failed&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="134" width="893" x="1312" y="1548" as="geometry" />
        </mxCell>
        <mxCell id="5VOFnX5OII6aDvyBcTs3-49" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fontColor=#000000;darkOpacity=0.05;fillColor=#FFF9B2;strokeColor=none;fillStyle=solid;direction=west;gradientDirection=north;gradientColor=#FFF2A1;shadow=1;size=20;pointerEvents=1;fontSize=18;align=left;" value="When it goes back to&amp;nbsp;&lt;span style=&quot;color: light-dark(rgb(78, 201, 176), rgb(6, 112, 90)); background-color: light-dark(rgb(18, 19, 20), rgb(220, 221, 222)); text-align: center; font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space: pre;&quot;&gt;MMTransaction &lt;/span&gt;&lt;span style=&quot;color: rgb(210, 168, 255); font-family: Consolas, &amp;quot;Courier New&amp;quot;, monospace; font-size: 14px; white-space: pre; background-color: rgb(18, 19, 20);&quot;&gt;emitTransactionEvent()&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;, it does：&lt;/span&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Update the&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;MMTransactionAPI substatus&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;&amp;nbsp;to success_indicator / failed_indicator depends on the response from MM&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;2. Send &lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt;MMTransactionAPI&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237));&quot;&gt; into channel&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="134" width="893" x="1312" y="1750" as="geometry" />
        </mxCell>
      </root>
